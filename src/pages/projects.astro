---
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProjects, otherProjects } from '../data/projects';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="项目作品 | 乱花 Personal Lab"
  description="查看乱花的重点公开项目与其他技术实践，涵盖 AI 摘要、Provider Gateway、Go WebSocket、全栈 MVP、手势识别与 DevOps。"
>
  <section class="section projects-section">
    <div class="section-head">
      <h1>项目作品</h1>
      <p>优先展示已经公开、边界清晰的完整 MVP；其他练习保留真实状态和当前限制。</p>
    </div>

    <section class="project-group" aria-labelledby="featured-project-group">
      <div class="project-group-heading">
        <div>
          <span>Featured</span>
          <h2 id="featured-project-group">重点项目</h2>
        </div>
        <p>四个已经完成仓库整理、适合作为个人作品入口的公开项目。</p>
      </div>
      <div class="projects-grid featured-projects-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="project-group secondary-project-group" aria-labelledby="other-project-group">
      <div class="project-group-heading">
        <div>
          <span>Practice</span>
          <h2 id="other-project-group">其他实践</h2>
        </div>
        <p>开源补丁、计算机视觉、本地 DevOps 实验和当前网站本身。</p>
      </div>
      <div class="projects-grid secondary-projects-grid">
        {otherProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </section>
</BaseLayout>
