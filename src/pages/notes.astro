---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    title: '项目复盘',
    desc: '记录项目从最小可运行版本到逐步打磨的过程，包括功能取舍、文案调整、演示准备和下一步计划。',
    related: 'Go WebSocket Chatroom / AI WeChat Digest / LabelHub AI / 个人网站改造',
    status: '持续整理',
  },
  {
    title: 'AI 应用笔记',
    desc: '整理 AI 总结、Mock AI Review、本地 Ollama 接入、AI Provider 配置等实践记录。',
    related: 'AI WeChat Digest MVP / LabelHub AI MVP / WebSocket Chatroom AI 助手',
    status: '持续整理',
  },
  {
    title: 'DevOps 实验记录',
    desc: '记录 Jenkins、Gitea、Harbor、Docker、Zabbix 等本地实验环境搭建、问题排查和验证过程。',
    related: 'CI/CD Lab / 多语言 Web 自动部署 / Zabbix 监控',
    status: '本地实验',
  },
  {
    title: 'AIoT / 物联网准备',
    desc: '记录 ESP32、MQTT、传感器、Web Dashboard 等方向的准备内容和后续尝试。',
    related: '下一阶段准备尝试 / 低成本可复刻小项目',
    status: '准备中',
  },
];

const pendingNotes = [
  {
    title: 'Go WebSocket Chatroom：从登录到实时通信',
    category: '项目复盘',
    desc: '整理聊天室项目里注册登录、会话状态、消息广播和前端交互的实现过程。',
    status: '待整理',
  },
  {
    title: 'AI WeChat Digest MVP：RSS 到每日晚报',
    category: 'AI 应用',
    desc: '记录从数据源抓取、文章去重、AI/Mock 总结到晚报生成的流程。',
    status: '待整理',
  },
  {
    title: 'LabelHub AI MVP：一个 AI 标注平台原型',
    category: '项目复盘',
    desc: '复盘动态表单、任务流转、Mock AI Review 和演示包装的设计取舍。',
    status: '待整理',
  },
  {
    title: '本地 CI/CD Lab：从代码提交到服务部署',
    category: 'DevOps 实验',
    desc: '整理 Jenkins、Gitea、Harbor、Docker 串起来时遇到的问题和验证方法。',
    status: '待整理',
  },
  {
    title: 'Zabbix 监控：给本地服务加可用性检查',
    category: 'DevOps 实验',
    desc: '记录 Jenkins、Gitea、Harbor 等服务的 Web 场景监控配置思路。',
    status: '待整理',
  },
  {
    title: 'ESP32 + MQTT + Web Dashboard 准备路线',
    category: 'AIoT / 物联网',
    desc: '整理一个低成本物联网小项目的准备路径，后续再逐步实现。',
    status: '准备中',
  },
];

const principles = [
  {
    title: '先记录真实过程',
    desc: '优先写真实遇到的问题和解决步骤，而不是为了显得完整而补概念。',
  },
  {
    title: '先项目，后总结',
    desc: '笔记从已经跑通过的小项目里长出来，而不是凭空写教程。',
  },
  {
    title: '保留下一步',
    desc: '每篇笔记都尽量留下后续改进方向，方便项目持续迭代。',
  },
];
---

<BaseLayout title="技术笔记 | 乱花" description="乱花的技术笔记，记录项目实践、工具配置、踩坑复盘和阶段性学习整理">
  <section class="section notes-section">
    <div class="section-head">
      <h1>技术笔记</h1>
      <p class="notes-tagline">记录项目实践、工具配置、踩坑复盘和阶段性学习整理。</p>
    </div>

    <div class="notes-intro">
      <p>
        这里不会一次性写成完整教程合集，而是把每个项目推进过程中真正遇到的问题、解决过程和复盘慢慢整理出来。
      </p>
    </div>

    <div class="notes-categories">
      <h2 class="notes-section-title">笔记分类</h2>
      <div class="notes-grid">
        {categories.map((cat) => (
          <article class="note-category-card">
            <h3>{cat.title}</h3>
            <p class="note-category-desc">{cat.desc}</p>
            <div class="note-category-meta">
              <span class="note-category-related">关联：{cat.related}</span>
              <span class="note-category-status">{cat.status}</span>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="notes-pending">
      <h2 class="notes-section-title">近期准备整理</h2>
      <div class="notes-list">
        {pendingNotes.map((note) => (
          <article class="note-item">
            <div class="note-item-header">
              <span class="note-tag">{note.category}</span>
              <span class="note-status">{note.status}</span>
            </div>
            <h3>{note.title}</h3>
            <p>{note.desc}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="notes-principles">
      <h2 class="notes-section-title">写作原则</h2>
      <div class="notes-grid">
        {principles.map((item) => (
          <article class="note-principle-card">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="notes-cta">
      <h2>先看项目，再看笔记</h2>
      <p>如果想了解这些笔记对应的实践，可以先从项目作品页开始。</p>
      <a href="/projects" class="notes-cta-btn">查看项目作品 →</a>
    </div>
  </section>
</BaseLayout>
