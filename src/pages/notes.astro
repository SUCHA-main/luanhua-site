---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const categories = [...new Set(notes.map((note) => note.data.category))];
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);

const principles = [
  {
    title: '只写已经发生的事',
    desc: '文章从真实代码、检查记录和已完成的项目整理中提炼，不补写不存在的用户反馈或线上效果。',
  },
  {
    title: '把边界写进正文',
    desc: '实现、验证、未测试和后续计划分别说明，让项目能力保持可核对。',
  },
  {
    title: '内容与项目互相连接',
    desc: '每篇复盘都保留项目页入口，后续可以继续补充同一项目的部署、测试和迭代记录。',
  },
];
---

<BaseLayout
  title="技术笔记 | 乱花 Personal Lab"
  description="乱花的真实项目复盘与技术笔记，记录实现路径、安全边界、验证结果和下一步计划。"
>
  <section class="section notes-section">
    <div class="section-head">
      <h1>技术笔记</h1>
      <p class="notes-tagline">从已经完成的项目里整理实现路径、取舍和下一步。</p>
    </div>

    <div class="notes-intro notes-system-intro">
      <div>
        <span>Published</span>
        <strong>{notes.length}</strong>
        <p>篇真实项目复盘</p>
      </div>
      <div>
        <span>Categories</span>
        <strong>{categories.length}</strong>
        <p>{categories.join(' / ') || '持续整理'}</p>
      </div>
      <p>
        这里只展示已经完成并能从项目代码与检查记录中核对的文章。实现、验证、未测试项和下一步会分别说明。
      </p>
    </div>

    <section class="notes-published" aria-labelledby="published-notes-title">
      <div class="notes-section-heading">
        <div>
          <span>Articles</span>
          <h2 id="published-notes-title">已发布</h2>
        </div>
        <p>按发布日期排序，元数据和正文在构建阶段完成校验。</p>
      </div>

      <div class="note-entry-list">
        {
          notes.map((note) => (
            <article class="note-entry-card">
              <div class="note-entry-meta">
                <span>{note.data.category}</span>
                <time datetime={note.data.publishedAt.toISOString()}>{formatDate(note.data.publishedAt)}</time>
              </div>
              <h2>
                <a href={`/notes/${note.id}`}>{note.data.title}</a>
              </h2>
              <p>{note.data.description}</p>
              <div class="note-entry-footer">
                <div class="note-entry-tags" aria-label={`${note.data.title} 标签`}>
                  {note.data.tags.map((tag) => <span>{tag}</span>)}
                </div>
                <a href={`/notes/${note.id}`} class="project-link" aria-label={`阅读 ${note.data.title}`}>
                  阅读复盘 →
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="notes-principles" aria-labelledby="notes-principles-title">
      <h2 class="notes-section-title" id="notes-principles-title">写作原则</h2>
      <div class="notes-grid">
        {
          principles.map((item) => (
            <article class="note-principle-card">
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>
