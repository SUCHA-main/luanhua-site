---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../config/site';
import { orderedProjects } from '../../data/projects';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf(),
  );

  return notes.map((note, index) => ({
    params: { slug: note.id },
    props: {
      note,
      previousNote: notes[index - 1],
      nextNote: notes[index + 1],
    },
  }));
}

interface Props {
  note: CollectionEntry<'notes'>;
  previousNote?: CollectionEntry<'notes'>;
  nextNote?: CollectionEntry<'notes'>;
}

const { note, previousNote, nextNote } = Astro.props;
const { Content } = await render(note);
const project = orderedProjects.find((item) => item.id === note.data.projectId);
const publishedAt = note.data.publishedAt.toISOString();
const displayDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(note.data.publishedAt);
---

<BaseLayout
  title={`${note.data.title} | ${siteConfig.authorName}技术笔记`}
  description={note.data.description}
  pageClass="note-article-page"
  ogType="article"
  publishedTime={publishedAt}
  updatedTime={note.data.updatedAt?.toISOString()}
  tags={note.data.tags}
  articleImage={note.data.cover}
  articleTitle={note.data.title}
>
  <article class="note-article-shell">
    <nav class="note-breadcrumb" aria-label="文章路径">
      <a href="/notes">技术笔记</a>
      <span aria-hidden="true">/</span>
      <span>{note.data.category}</span>
    </nav>

    <header class="note-article-header">
      <span class="note-article-category">{note.data.category}</span>
      <h1>{note.data.title}</h1>
      <p>{note.data.description}</p>
      <div class="note-article-meta">
        <time datetime={publishedAt}>{displayDate}</time>
        <span>{note.data.tags.length} 个标签</span>
      </div>
      <div class="note-article-tags" aria-label="文章标签">
        {note.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>

    <div class="note-article-prose">
      <Content />
    </div>

    {
      (previousNote || nextNote) && (
        <nav class="note-article-navigation" aria-label="文章上一篇和下一篇">
          <div class="note-navigation-heading">
            <span>Continue Reading</span>
            <h2>继续阅读</h2>
          </div>
          <div class="note-navigation-grid">
            {previousNote && (
              <a href={`/notes/${previousNote.id}`} class="note-navigation-link previous">
                <span>← 上一篇</span>
                <strong>{previousNote.data.title}</strong>
              </a>
            )}
            {nextNote && (
              <a href={`/notes/${nextNote.id}`} class="note-navigation-link next">
                <span>下一篇 →</span>
                <strong>{nextNote.data.title}</strong>
              </a>
            )}
          </div>
        </nav>
      )
    }

    <footer class="note-article-footer">
      <div>
        <span>Related Project</span>
        <h2>{project?.title ?? 'AI WeChat Digest MVP'}</h2>
        <p>{project?.subtitle ?? '从 RSS 到结构化每日晚报的 Mock-first AI 应用 MVP。'}</p>
      </div>
      <div class="note-article-actions">
        <a href={`/projects#${note.data.projectId}`} class="project-action-btn primary">返回项目页</a>
        <a href="/notes" class="project-action-btn secondary">全部笔记</a>
      </div>
    </footer>
  </article>
</BaseLayout>
