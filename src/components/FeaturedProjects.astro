---
import { featuredProjects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section class="content-section featured-section" aria-labelledby="featured-projects-title" data-reveal>
  <div class="section-heading soft-heading" data-reveal>
    <span>Projects</span>
    <h2 id="featured-projects-title">精选项目</h2>
    <p>优先展示边界清晰、已经公开并完成基础整理的四个项目。</p>
  </div>

  <div class="project-card-grid">
    {featuredProjects.map((project) => <ProjectCard project={project} variant="featured" />)}
  </div>

  <div class="featured-projects-footer" data-reveal>
    <a href="/projects" class="project-action-btn secondary">查看全部项目 →</a>
  </div>
</section>
