<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const body = document.body;
  const floatingNav = document.querySelector('.site-header.floating');
  const revealItems = document.querySelectorAll('[data-reveal]');
  const scrollHint = document.querySelector('.scroll-hint');
  const labHero = document.querySelector<HTMLElement>('.personal-lab-hero');
  const parallaxLayers = document.querySelectorAll<HTMLElement>('[data-depth]');

  body.classList.add('motion-ready');

  function updateNavState() {
    if (!floatingNav) return;
    floatingNav.classList.toggle('is-scrolled', window.scrollY > 24);
  }

  updateNavState();
  window.addEventListener('scroll', updateNavState, { passive: true });

  if (prefersReducedMotion) {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  } else if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
    );

    revealItems.forEach((item) => observer.observe(item));
  } else {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  }

  scrollHint?.addEventListener('click', (event) => {
    const target = document.querySelector('#focus');
    if (!target) return;
    event.preventDefault();
    target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
  });

  if (!prefersReducedMotion && labHero && parallaxLayers.length > 0 && window.matchMedia('(pointer: fine)').matches) {
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let frameRequested = false;

    function updateLayers() {
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      parallaxLayers.forEach((layer) => {
        const depth = Number(layer.getAttribute('data-depth') || 0);
        const x = currentX * depth;
        const y = currentY * depth;
        const rotate = currentX * depth * 0.012;
        layer.style.transform = `translate3d(${x}px, ${y}px, 0) rotate(${rotate}deg)`;
      });

      frameRequested = Math.abs(targetX - currentX) > 0.001 || Math.abs(targetY - currentY) > 0.001;
      if (frameRequested) requestAnimationFrame(updateLayers);
    }

    function requestLayerUpdate() {
      if (frameRequested) return;
      frameRequested = true;
      requestAnimationFrame(updateLayers);
    }

    labHero.addEventListener('pointermove', (event: PointerEvent) => {
      const rect = labHero.getBoundingClientRect();
      targetX = (event.clientX - rect.left) / rect.width - 0.5;
      targetY = (event.clientY - rect.top) / rect.height - 0.5;
      requestLayerUpdate();
    });

    labHero.addEventListener('pointerleave', () => {
      targetX = 0;
      targetY = 0;
      requestLayerUpdate();
    });
  }
</script>
