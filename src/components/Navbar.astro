---
interface Props {
  variant?: 'default' | 'floating';
}

const { variant = 'default' } = Astro.props;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/projects', label: '项目作品' },
  { href: '/notes', label: '技术笔记' },
  { href: '/about', label: '关于我' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class:list={['site-header', variant]}>
  <a class="brand" href="/" aria-label="乱花首页">
    <span class="brand-mark">乱</span>
    <span>乱花</span>
  </a>
  <nav class="site-nav" aria-label="主导航">
    {
      navItems.map((item) => {
        const normalizedHref = item.href.replace(/\/$/, '') || '/';
        const active = pathname === normalizedHref;
        return (
          <a href={item.href} class:list={[{ active }]} aria-current={active ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })
    }
  </nav>
</header>
